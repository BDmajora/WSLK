<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <outputs>
    <output>
      <name>__OUTPUT__</name>
      <mode>preferred</mode>
    </output>
  </outputs>

  <desktops>
    <number>1</number>
    <names><name>WSLK</name></names>
  </desktops>

  <windowRules>
    <windowRule identifier="Shell_TrayWnd" serverDecoration="no" skipTaskbar="yes" skipPager="yes">
      <action name="MoveTo" x="0" y="__TASKBAR_Y__" />
    </windowRule>
    
    <windowRule identifier="explorer.exe" serverDecoration="no" skipTaskbar="yes" skipPager="yes" />
    
    <windowRule identifier="wine" serverDecoration="no" />
  </windowRules>

  <applications>
    <application class="Shell_TrayWnd">
      <decor>no</decor>
      <layer>above</layer>
      <position force="yes">
        <x>0</x>
        <y>__TASKBAR_Y__</y>
      </position>
    </application>
    <application class="explorer.exe">
      <decor>no</decor>
      <position force="yes">
        <x>0</x>
        <y>0</y>
      </position>
    </application>
    <application class="*">
      <decor>no</decor>
    </application>
  </applications>
</openbox_config>