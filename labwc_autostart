#!/bin/bash

# Apply Wine registry fixes now that we're inside a live Wayland session
if [ -f "$HOME/.wslk_prefs.reg" ]; then
    echo "Applying Wine registry fixes..." >> /tmp/wslk_autostart.log
    WINEPREFIX="$HOME/.wine" \
    WINEWAYLAND=1 \
    DISPLAY="" \
    wine regedit /s "$HOME/.wslk_prefs.reg" >> /tmp/wslk_autostart.log 2>&1
fi

# Background
swaybg -c "#366ea5" &

sleep 1

# Get resolution
RES=$(wlr-randr 2>/dev/null | awk '/[0-9]+x[0-9]+/ && /current/ {print $1; exit}')
[ -z "$RES" ] && RES=$(wlr-randr 2>/dev/null | awk 'match($0, /[0-9]+x[0-9]+/) {print substr($0, RSTART, RLENGTH); exit}')
[ -z "$RES" ] && RES="1280x800"

WIDTH=$(echo "$RES" | cut -dx -f1)
HEIGHT=$(echo "$RES" | cut -dx -f2)
TASKBAR_H=30
TASKBAR_Y=$((HEIGHT - TASKBAR_H))

echo "Resolution: ${WIDTH}x${HEIGHT}, taskbar Y: $TASKBAR_Y" >> /tmp/wslk_autostart.log

# Launch Wine shell
WINEPREFIX="$HOME/.wine" \
WINEWAYLAND=1 \
DISPLAY="" \
wine explorer /desktop=shell,"$RES" >> /tmp/wslk_autostart.log 2>&1 &

# Wait for taskbar window then force it to the bottom
(
    sleep 3
    if command -v wlrctl &>/dev/null; then
        wlrctl window move Shell_TrayWnd 0 "$TASKBAR_Y" 2>/dev/null && exit 0
    fi
    if command -v wmctrl &>/dev/null; then
        WID=$(wmctrl -l | grep -i "tray\|taskbar\|Shell_TrayWnd" | awk '{print $1}' | head -1)
        [ -n "$WID" ] && wmctrl -ir "$WID" -e "0,0,$TASKBAR_Y,$WIDTH,$TASKBAR_H"
    fi
) &