#!/bin/bash

# 1. WAIT FOR REAL HARDWARE DATA
# Loops until wlr-randr reports a resolution. Prevents the 800px fallback bug.
RES=""
while [ -z "$RES" ]; do
    RES=$(wlr-randr 2>/dev/null | awk '/preferred, current/ {print $1; exit}')
    [ -z "$RES" ] && sleep 0.1
done

OUTPUT=$(wlr-randr 2>/dev/null | awk '/^[A-Za-z]/ {name=$1} /preferred, current/ {print name; exit}')
WIDTH=$(echo "$RES" | cut -dx -f1)
HEIGHT=$(echo "$RES" | cut -dx -f2)

# 2. DYNAMIC MATH
# Using 30px for standard Wine taskbar height to prevent the bottom gap.
TASKBAR_Y=$((HEIGHT - 30))

# 3. RUNTIME INJECTION
# Replaces placeholders in rc.xml with real-time hardware data.
CONFIG_FILE="$HOME/.config/labwc/rc.xml"
if [ -f "$CONFIG_FILE" ]; then
    sed -i "s/__TASKBAR_Y__/$TASKBAR_Y/g" "$CONFIG_FILE"
    sed -i "s/__OUTPUT__/$OUTPUT/g" "$CONFIG_FILE"
    
    # Force labwc to snap windows to the new coordinates immediately
    labwc --reconfigure
fi

# 4. STARTUP SERVICES
swaybg -c "#366ea5" &

# Force the mode so QEMU doesn't scale/double
wlr-randr --output "$OUTPUT" --mode "$RES" >> /tmp/wslk_autostart.log 2>&1

# Apply Wine registry fixes
if [ -f "$HOME/.wslk_prefs.reg" ]; then
    WINEPREFIX="$HOME/.wine" WINEWAYLAND=1 DISPLAY="" \
    wine regedit /s "$HOME/.wslk_prefs.reg" >> /tmp/wslk_autostart.log 2>&1
fi

# 5. LAUNCH EXPLORER
WINEPREFIX="$HOME/.wine" \
WINEWAYLAND=1 \
DISPLAY="" \
wine explorer /desktop=shell,"$RES" >> /tmp/wslk_autostart.log 2>&1 &