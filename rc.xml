<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc"
                xmlns:xi="http://www.w3.org/2001/XInclude">

  <outputs>
    <output>
      <name>__OUTPUT__</name>
      <mode>preferred</mode>
    </output>
  </outputs>

  <focus>
    <followMouse>no</followMouse>
    <focusLast>yes</focusLast>
    <underMouse>no</underMouse>
    <focusDelay>200</focusDelay>
  </focus>

  <desktops>
    <number>1</number>
    <firstdesk>1</firstdesk>
    <names><name>WSLK</name></names>
  </desktops>

  <keyboard>
    <keybind key="W-t">
      <action name="Execute"><command>foot</command></action>
    </keybind>
    <keybind key="W-S-q">
      <action name="Exit"/>
    </keybind>
  </keyboard>

  <mouse>
    <dragThreshold>1</dragThreshold>
    <doubleClickTime>500</doubleClickTime>
  </mouse>

  <windowRules>
    <windowRule identifier="Shell_TrayWnd" serverDecoration="no" skipTaskbar="yes" skipPager="yes">
      <action name="MoveTo" x="0" y="-0" />
    </windowRule>
    <windowRule identifier="explorer.exe" serverDecoration="no" skipTaskbar="yes" skipPager="yes">
      <action name="MoveTo" x="0" y="-0" />
    </windowRule>
    <windowRule identifier="wine" serverDecoration="no" skipTaskbar="yes" skipPager="yes">
      <action name="MoveTo" x="0" y="-0" />
    </windowRule>
  </windowRules>

  <applications>
    <application class="Shell_TrayWnd">
      <decor>no</decor>
      <layer>above</layer>
      <focus>no</focus>
      <position force="yes">
        <x>0</x>
        <y>-0</y>
      </position>
    </application>

    <application class="explorer.exe">
      <decor>no</decor>
      <layer>above</layer>
      <focus>no</focus>
      <position force="yes">
        <x>0</x>
        <y>-0</y>
      </position>
    </application>

    <application class="*">
      <decor>no</decor>
    </application>
  </applications>

</openbox_config>