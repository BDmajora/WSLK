<?xml version="1.0" encoding="UTF-8"?>
<labwc_config>
  <core>
    <decoration>none</decoration>
    <gap>0</gap>
  </core>
  <keyboard>
    <default />
    <keybind key="W-t">
      <action name="Execute" command="foot" />
    </keybind>
    <keybind key="W-S-q">
      <action name="Exit" />
    </keybind>
  </keyboard>
  <windowRules>
    <windowRule identifier="wine*" maximize="yes" serverDecoration="no" borderless="yes">
      <action name="MoveTo" x="0" y="0" />
    </windowRule>
  </windowRules>
</labwc_config>